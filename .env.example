# ─────────────────────────────────────────────────────────────────────────────
# Cult Content Scheduler — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Lark / Feishu ────────────────────────────────────────────────────────────
LARK_APP_ID=
LARK_APP_SECRET=
LARK_BITABLE_APP_TOKEN=         # The Content Scheduler base token
LARK_BITABLE_TABLE_ID=          # The posting queue table ID
LARK_ALERT_CHAT_ID=             # Lark group chat for token expiry alerts (optional)

# ── GoHighLevel ───────────────────────────────────────────────────────────────
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_BASE_URL=https://services.leadconnectorhq.com

# ── Buffer (all platform posting except brand TikTok) ─────────────────────────
BUFFER_API_KEY=

# YouTube channel IDs
BUFFER_YOUTUBE_CULT_CONTENT_ID=
BUFFER_YOUTUBE_TOMMY_ID=

# Instagram channel IDs
BUFFER_IG_CULT_ID=
BUFFER_IG_TOMMY_ID=

# LinkedIn channel IDs
BUFFER_LI_CULT_ID=
BUFFER_LI_TOMMY_ID=

# Facebook
BUFFER_FACEBOOK_CULT_ID=

# X / Twitter
BUFFER_X_ID=

# TikTok (personal — business TikTok still via GHL)
BUFFER_TIKTOK_TOMMY_ID=

# ── PhantomBuster (legacy X/Twitter fallback) ─────────────────────────────────
PHANTOM_API_KEY=
PHANTOM_AGENT_ID=
PHANTOM_SESSION_COOKIE=         # x.com auth_token cookie — expires periodically

# ── OpenAI (Whisper transcription for video editing) ─────────────────────────
OPENAI_API_KEY=

# ── Shotstack (video rendering) ───────────────────────────────────────────────
SHOTSTACK_API_KEY_SANDBOX=
SHOTSTACK_OWNER_ID_SANDBOX=
SHOTSTACK_API_KEY_PROD=
SHOTSTACK_OWNER_ID_PROD=

# ── Config ────────────────────────────────────────────────────────────────────
RECONNECT_WARNING_DAYS=7        # Days before token expiry to trigger alert
